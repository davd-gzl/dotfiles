# Catppuccin Mocha base
font=JetBrainsMono Nerd Font 11
background-color=#1e1e2eee
text-color=#cdd6f4
border-color=#cba6f7
border-size=2
border-radius=12
padding=14
margin=12
default-timeout=6000
icons=1
max-icon-size=48
layer=overlay
anchor=top-right
sort=-time
format=<b>%s</b>\n%b

[urgency=low]
border-color=#a6e3a1

[urgency=normal]
border-color=#cba6f7

[urgency=critical]
border-color=#f38ba8
default-timeout=8000

# Claude Code — larger, slightly longer, click-to-focus
[app-name="Claude Code"]
border-size=3
width=460
height=180
font=JetBrainsMono Nerd Font 12
padding=18
default-timeout=8000
on-button-left=exec /home/davd/.claude/notify-click.sh $id

# Per-event colors (Catppuccin Mocha palette) — distinguishes the kind of
# attention needed at a glance.

# Done — green
[app-name="Claude Code" category=claude-done]
border-color=#a6e3a1

# Error/crash — red
[app-name="Claude Code" category=claude-error]
border-color=#f38ba8

# Idle / waiting for input — mauve
[app-name="Claude Code" category=claude-waiting]
border-color=#cba6f7

# AskUserQuestion — yellow
[app-name="Claude Code" category=claude-question]
border-color=#f9e2af

# Tool permission requested — peach
[app-name="Claude Code" category=claude-permission]
border-color=#fab387

# Elicitation (MCP structured input) — sky
[app-name="Claude Code" category=claude-elicit]
border-color=#89dceb
